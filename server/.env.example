# ── OpenAI ────────────────────────────────────────────────────────────────────
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Optional overrides ────────────────────────────────────────────────────────
# Text-only model (Stage A). gpt-4o-mini is fast and cheap.
# OPENAI_MODEL=gpt-4o-mini

# Vision model (Stage B — used when text confidence is low).
# Must support vision (image inputs). gpt-4o is the default.
# OPENAI_VISION_MODEL=gpt-4o

# Port the server listens on (default: 3001)
# PORT=3001
