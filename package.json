{
  "name": "event-importer",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "server": "npm --prefix server run dev",
    "export:web": "expo export --platform web",
    "patch:ghpages": "node scripts/patch-ghpages.js",
    "deploy": "npm run export:web && npm run patch:ghpages && gh-pages -d dist --nojekyll",
    "dev": "concurrently --names \"APP,SERVER\" --prefix-colors \"blue,green\" \"npm run web\" \"npm run server\""
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "chrono-node": "^2.9.0",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-auth-session": "~6.0.0",
    "expo-constants": "~17.0.3",
    "expo-file-system": "~18.0.12",
    "expo-image-picker": "~16.0.3",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.0",
    "expo-web-browser": "~14.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.0.0",
    "react-native-web": "~0.19.13",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.3.12",
    "concurrently": "^8.2.2",
    "gh-pages": "^6.3.0",
    "replace-in-file": "^8.4.0",
    "typescript": "^5.3.0"
  }
}
